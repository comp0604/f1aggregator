name: F1 News Daily Update

on:
  schedule:
    # 하루 2번 정기 실행 (한국 시각 오전 8시, 오후 8시)
    - cron: '0 11,23 * * *'
  workflow_dispatch: # 수동 테스트 버턴 활성화

jobs:
  update-news:
    runs-on: ubuntu-latest
    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt

    - name: Run Aggregator (News Only)
      env:
        OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
      run: |
        python cron_aggregator.py

    - name: Commit and Push DB Changes
      run: |
        git config --global user.name "GitHub Actions"
        git config --global user.email "actions@github.com"
        git add f1_news.db
        # 뉴스가 추가되어 DB 변경점이 생겼을 때만 조건부 커밋
        git diff --quiet && git diff --staged --quiet || (git commit -m "🤖 뉴스 애그리게이터 정기 업데이트 완료" && git push)