name: F1 News Daily Update

on:
  schedule:
    # UTC 기준 시간 (한국 시간 = UTC + 9시)
    # 하루 2번: 한국 시간 오전 8시(23:00 UTC), 오후 8시(11:00 UTC)에 실행
    - cron: '0 11,23 * * *'
  workflow_dispatch: # 필요할 때 깃허브 웹에서 수동으로 실행 가능하게 함

jobs:
  update-news:
    runs-on: ubuntu-latest
    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/checkout@v4
      with:
        python-version: '3.11'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt

    - name: Run Aggregator
      env:
        OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
      run: |
        python cron_aggregator.py

    - name: Commit and Push DB Changes
      run: |
        git config --global user.name "GitHub Actions"
        git config --global user.email "actions@github.com"
        git add f1_news.db
        # 변경 사항이 있을 때만 커밋
        git diff --quiet && git diff --staged --quiet || (git commit -m "🤖 자동 뉴스 업데이트" && git push)