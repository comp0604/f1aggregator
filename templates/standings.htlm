<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏆 드라이버 순위 - LecLovF1</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; font-family: 'Malgun Gothic', sans-serif; }
        .f1-header { background-color: #e10600; color: white; padding: 2rem 0; margin-bottom: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .card { border: none; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .table-f1 th { background-color: #212529; color: white; text-align: center; }
        .table-f1 td { vertical-align: middle; text-align: center; }
        /* 포디움 하이라이트 스타일 */
        .podium-1 { background-color: #fff3cd !important; font-weight: bold; }
        .podium-2 { background-color: #e2e3e5 !important; }
        .podium-3 { background-color: #f8d7da !important; }
        a { text-decoration: none; }
    </style>
</head>
<body>

    <header class="f1-header text-center">
        <div class="container">
            <h1 class="fw-bold">🏎️ LecLovF1</h1>
            <p class="lead mb-3">2026 시즌 F1 월드 챔피언십 실시간 순위 스코어보드</p>
            <div class="mt-3">
                <a href="/" class="btn btn-outline-light fw-bold px-4 me-2 shadow-sm">📰 최신 뉴스</a>
                <a href="/standings" class="btn btn-light text-danger fw-bold px-4 me-2 shadow-sm">🏆 드라이버 순위</a>
                <a href="/calendar" class="btn btn-outline-light fw-bold px-4 shadow-sm">📅 경기 일정</a>
            </div>
        </div>
    </header>

    <main class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card p-4">
                    <h3 class="h4 fw-bold mb-4 text-dark">🏁 드라이버 챔피언십 순위</h3>
                    
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered table-f1 mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 15%;">순위</th>
                                    <th style="width: 45%;">드라이버 이름</th>
                                    <th style="width: 25%;">소속 팀</th>
                                    <th style="width: 15%;">포인트</th>
                                </tr>
                            </thead>
                            <tbody id="standings-rows">
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <div class="spinner-border text-danger role="status" style="width: 1.5rem; height: 1.5rem;"></div>
                                        <span class="ms-2">실시간 순위 데이터를 가져오는 중...</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="text-center text-muted py-4 mt-5 border-top">
        <p>© 2026 F1 뉴스 애그리게이터 파이프라인 프로젝트</p>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const apiUrl = "https://api.jolpi.ca/ergast/f1/2026/driverStandings.json";
            const tableBody = document.getElementById("standings-rows");

            fetch(apiUrl)
                .then(response => response.json())
                .then(data => {
                    const standingsLists = data.MRData.StandingsTable.StandingsLists;
                    
                    // 만약 데이터가 아직 안 올라왔을 경우 예외 처리
                    if (!standingsLists || standingsLists.length === 0) {
                        tableBody.innerHTML = `<tr><td colspan="4" class="text-center py-4 text-muted">아직 2026 시즌 순위 데이터가 생성되지 않았습니다.</td></tr>`;
                        return;
                    }

                    const driverStandings = standingsLists[0].DriverStandings;
                    let htmlContent = "";

                    driverStandings.forEach(item => {
                        const pos = parseInt(item.position);
                        const driverName = `${item.Driver.givenName} ${item.Driver.familyName}`;
                        const constructorName = item.Constructors.length > 0 ? item.Constructors[0].name : "Unknown";
                        const points = item.points;

                        // 1, 2, 3위 배경색 클래스 지정
                        let rowClass = "";
                        if (pos === 1) rowClass = "podium-1";
                        else if (pos === 2) rowClass = "podium-2";
                        else if (pos === 3) rowClass = "podium-3";

                        htmlContent += `
                            <tr class="${rowClass}">
                                <td class="fw-bold">${pos}</td>
                                <td class="text-start ps-4 fw-bold text-dark">${driverName}</td>
                                <td><span class="badge bg-secondary">${constructorName}</span></td>
                                <td class="fw-bold text-danger">${points} P</td>
                            </tr>
                        `;
                    });

                    // 표 내부 교체
                    tableBody.innerHTML = htmlContent;
                })
                .catch(error => {
                    console.error("API 호출 오류:", error);
                    tableBody.innerHTML = `<tr><td colspan="4" class="text-center py-4 text-danger">⚠️ 데이터를 불러오는 중 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.</td></tr>`;
                });
        });
    </script>
</body>
</html>